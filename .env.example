ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6-20251001
DEEPGRAM_API_KEY=your_deepgram_key_here
DEEPGRAM_SPEAK_MODEL=aura-2-asteria-en

# Frontend — copy to .env.local (or set in root .env for Vite)
# Option A (recommended with npm run dev): use the Vite proxy
# VITE_API_BASE=/api
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001
#
# Option B: call the backend directly (backend must be on port 3001)
# VITE_API_BASE=http://127.0.0.1:3001
