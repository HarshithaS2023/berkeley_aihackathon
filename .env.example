ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6-20251001
DEEPGRAM_API_KEY=your_deepgram_key_here
DEEPGRAM_SPEAK_MODEL=aura-2-asteria-en

# Arize AX — LLM tracing (optional; omit to disable)
# ARIZE_SPACE_ID=your-space-id
# ARIZE_API_KEY=your-arize-api-key
# ARIZE_PROJECT_NAME=quizcraft

# Frontend — copy to .env.local (or set in root .env for Vite)
# Option A (recommended with npm run dev): use the Vite proxy
# VITE_API_BASE=/api
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001
#
# Option B: call the backend directly (backend must be on port 3001)
# VITE_API_BASE=http://127.0.0.1:3001

# Supabase (Project Settings → API)
# Enable Email auth under Authentication → Providers in the Supabase dashboard.
# Run supabase/auth_migration.sql if tables already exist with open RLS.
# VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
